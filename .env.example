# FunCode — local secrets (NEVER commit). Copy to .env.local and fill in.
# Below the waterline (BR-3). Cursor hooks require human approval before agents read this file.

# --- Required for ingest/ pipeline (PAT-8, LAND-25) ---
# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Whisper model routed via OpenRouter (override if needed)
OPENROUTER_STT_MODEL=openai/whisper-large-v3

# Chat model for PAT-7 Chain extraction step
OPENROUTER_EXTRACT_MODEL=anthropic/claude-sonnet-4

# --- Optional ---
# OPENROUTER_HTTP_REFERER=https://funcode.club
# OPENROUTER_APP_NAME=FunCode Ingest

# --- NOT production — ingest runs locally only ---
# Production keys and deploy credentials do NOT belong in this file.
